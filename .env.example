# GitHub REST API Token (classic or fine-grained)
GITHUB_TOKEN=your_github_token_here

# Stack Exchange API (Stack Overflow) Keys
STACK_EXCHANGE_KEY=your_stack_exchange_key_here
STACK_EXCHANGE_ACCESS_TOKEN=your_stack_exchange_access_token_here

# dev.to API Key
DEVTO_API_KEY=your_devto_api_key_here

# Hacker News (Algolia Search API) Keys (Optional for public searches)
HN_ALGOLIA_APP_ID=your_hn_algolia_app_id_here
HN_ALGOLIA_API_KEY=your_hn_algolia_api_key_here
